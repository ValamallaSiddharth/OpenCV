   "source": [
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "img = cv2.imread(\"demon.png\")\n",
    "\n",
    "img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n",
    "\n",
    "flip = cv2.flip(img, 1)\n",
    "\n",
    "plt.imshow(flip)\n",
    "plt.title(\"Flipped Image\")\n",
    "plt.axis('off')\n",
    "plt.show()"
   ]
  },
