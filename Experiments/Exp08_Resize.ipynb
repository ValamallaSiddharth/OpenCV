   "source": [
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Read image\n",
    "img = cv2.imread('demon.png')\n",
    "\n",
    "# Resize image\n",
    "resized = cv2.resize(img, (500, 500))\n",
    "\n",
    "plt.subplot(1,2,2)\n",
    "plt.imshow(cv2.cvtColor(resized, cv2.COLOR_BGR2RGB))\n",
    "plt.title(\"Resized Image\")\n",
    "plt.axis('off')\n",
    "\n",
    "plt.show()"
   ]
