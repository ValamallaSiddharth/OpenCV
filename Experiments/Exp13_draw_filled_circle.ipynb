   "source": [
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "img = cv2.imread(\"demon.png\")\n",
    "img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n",
    "\n",
    "cv2.circle(img, (110,110), 60, (255,0,0), -1)\n",
    "\n",
    "plt.imshow(img)\n",
    "plt.title(\"Filled Circle\")\n",
    "plt.axis('off')\n",
    "plt.show()"
   ]
