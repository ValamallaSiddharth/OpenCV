   "source": [
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "img = cv2.imread(\"demon.png\")\n",
    "\n",
    "img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n",
    "\n",
    "blur = cv2.GaussianBlur(img, (11, 11), 0)\n",
    "\n",
    "plt.imshow(blur)\n",
    "plt.title(\"Blurred Image\")\n",
    "plt.axis('off')\n",
    "plt.show()"
   ]
